import random

palavras = ["python", "escola", "computador", "programação", "jogo"]

palavra = random.choice(palavras)  # Selecione uma palavra aleatória
letras_descobertas = ["_"] * len(palavra)  # Cria uma lista de underscores
tentativas = 6

print("Jogo da Forca")

while tentativas > 0 and "_" in letras_descobertas:
    print("\nPalavra:", "".join(letras_descobertas))
    letra = input("Digite uma letra: ").lower()

    if letra in palavra:
        # Atualiza as letras descobertas onde a letra correta foi encontrada
        for i in range(len(palavra)):
            if palavra[i] == letra:
                letras_descobertas[i] = letra
        print("Boa! Você acertou uma letra.")
    else:
        tentativas -= 1
        print(f"X Letra errada! Tentativas restantes: {tentativas}")
    
    if "_" not in letras_descobertas:
        print("\nParabéns! Você acertou a palavra:", palavra)
    elif tentativas == 0:
        print("\nVocê perdeu! A palavra era:", palavra)
